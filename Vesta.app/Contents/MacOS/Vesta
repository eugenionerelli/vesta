#!/bin/bash
# Launcher Vesta: avvia il server (se non gia' attivo) e apre il browser.
# Percorsi relativi al bundle: funziona ovunque venga clonato il repo.
HERE="$(cd "$(dirname "$0")/../../.." && pwd)"
DIR="$HERE/backend"
PORT=8770
URL="http://127.0.0.1:${PORT}/"
cd "$DIR" || exit 1

if lsof -ti "tcp:${PORT}" >/dev/null 2>&1; then
  open "$URL"
  exit 0
fi

(
  for i in $(seq 1 90); do
    curl -s "${URL}health" >/dev/null 2>&1 && break
    sleep 1
  done
  open "$URL"
) &

exec ./.venv/bin/python -m uvicorn server:app --host 0.0.0.0 --port "${PORT}"
